// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// ENUM DEFINITIONS
// ==========================================

enum RoleName {
  CUSTOMER
  CREATOR
  SALON
  ADMIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum IdType {
  PASSPORT
  DRIVERS_LICENSE
  NATIONAL_ID
}

enum VideoStatus {
  DRAFT
  PROCESSING
  ACTIVE
  BLOCKED
  DELETED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  PAYMENT
  EARNING
  REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum WithdrawStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum EarningSource {
  COURSE_SALE
  BOOKING_COMMISSION
  AD_REVENUE
  TIPS
}

enum NotificationType {
  SYSTEM
  LIKE
  COMMENT
  FOLLOW
  BOOKING
  EARNING
  COURSE
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

// ==========================================
// MODELS
// ==========================================

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String?   @unique @db.VarChar(255)
  phone        String?   @unique @db.VarChar(50)
  firebase_uid String    @unique @db.VarChar(255)
  display_name String?   @db.VarChar(100)
  avatar_url   String?   @db.Text
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now()) @db.Timestamp
  updated_at   DateTime  @updatedAt @db.Timestamp
  deleted_at   DateTime? @db.Timestamp

  // Relations
  roles              UserRole[]
  creator_profile    CreatorProfile?
  salon_profiles     SalonProfile[]
  reviewed_creators  CreatorKyc[]       @relation("CreatorKycReviewer")
  reviewed_salons    SalonKyc[]         @relation("SalonKycReviewer")
  video_views        VideoView[]
  video_likes        VideoLike[]
  video_comments     VideoComment[]
  video_shares       VideoShare[]
  saved_videos       SavedVideo[]
  watch_history      WatchHistory[]
  followers          Follower[]         @relation("Follower")
  following          Follower[]         @relation("Following")
  bookings           Booking[]          @relation("CustomerBookings")
  staff_profile      Staff?
  reviews            Review[]
  wallet             Wallet?
  withdraw_requests  WithdrawRequest[]
  course_enrollments CourseEnrollment[]
  earnings           Earning[]
  notifications      Notification[]
  reports_filed      Report[]           @relation("ReportReporter")
  reports_against    Report[]           @relation("ReportTargetUser")
  resolved_reports   Report[]           @relation("ReportResolver")
  audit_logs         AuditLog[]
  search_history     SearchHistory[]
  devices            Device[]
  sessions           Session[]

  @@index([firebase_uid])
  @@index([deleted_at])
  @@map("users")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        RoleName @unique
  description String?  @db.Text
  created_at  DateTime @default(now()) @db.Timestamp
  updated_at  DateTime @updatedAt @db.Timestamp

  // Relations
  users UserRole[]

  @@map("roles")
}

model UserRole {
  user_id    String   @db.Uuid
  role_id    String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamp

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([user_id, role_id])
  @@map("user_roles")
}

model CreatorProfile {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String         @unique @db.Uuid
  bio              String?        @db.Text
  instagram_handle String?        @db.VarChar(100)
  tiktok_handle    String?        @db.VarChar(100)
  youtube_handle   String?        @db.VarChar(100)
  website_url      String?        @db.Text
  is_verified      Boolean        @default(false)
  status           ApprovalStatus @default(PENDING)
  rejected_reason  String?        @db.Text
  created_at       DateTime       @default(now()) @db.Timestamp
  updated_at       DateTime       @updatedAt @db.Timestamp
  deleted_at       DateTime?      @db.Timestamp

  // Relations
  user    User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  kyc     CreatorKyc?
  videos  Video[]
  courses Course[]
  reviews Review[]

  @@index([deleted_at])
  @@map("creator_profiles")
}

model CreatorKyc {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creator_profile_id String    @unique @db.Uuid
  full_name          String    @db.VarChar(255)
  id_type            IdType
  id_number          String    @db.VarChar(100)
  id_front_url       String    @db.Text
  id_back_url        String?   @db.Text
  selfie_url         String    @db.Text
  status             KycStatus @default(PENDING)
  rejection_reason   String?   @db.Text
  submitted_at       DateTime  @default(now()) @db.Timestamp
  reviewed_at        DateTime? @db.Timestamp
  reviewed_by        String?   @db.Uuid
  created_at         DateTime  @default(now()) @db.Timestamp
  updated_at         DateTime  @updatedAt @db.Timestamp

  // Relations
  creator_profile CreatorProfile @relation(fields: [creator_profile_id], references: [id], onDelete: Cascade)
  reviewer        User?          @relation("CreatorKycReviewer", fields: [reviewed_by], references: [id], onDelete: SetNull)

  @@map("creator_kyc")
}

model SalonProfile {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String         @db.Uuid
  name            String         @db.VarChar(255)
  logo_url        String?        @db.Text
  description     String?        @db.Text
  address         String         @db.Text
  city            String         @db.VarChar(100)
  state           String         @db.VarChar(100)
  zip_code        String         @db.VarChar(20)
  country         String         @db.VarChar(100)
  latitude        Float?
  longitude       Float?
  phone           String         @db.VarChar(50)
  email           String?        @db.VarChar(255)
  website         String?        @db.Text
  business_hours  Json           @default("{}")
  is_verified     Boolean        @default(false)
  status          ApprovalStatus @default(PENDING)
  rejected_reason String?        @db.Text
  created_at      DateTime       @default(now()) @db.Timestamp
  updated_at      DateTime       @updatedAt @db.Timestamp
  deleted_at      DateTime?      @db.Timestamp

  // Relations
  user     User      @relation(fields: [user_id], references: [id], onDelete: Restrict)
  kyc      SalonKyc?
  services Service[]
  staff    Staff[]
  gallery  Gallery[]
  offers   Offer[]
  bookings Booking[]
  reviews  Review[]

  @@index([city])
  @@index([state])
  @@index([latitude, longitude])
  @@index([deleted_at])
  @@map("salon_profiles")
}

model SalonKyc {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  salon_profile_id    String    @unique @db.Uuid
  business_name       String    @db.VarChar(255)
  registration_number String    @db.VarChar(100)
  tax_id              String?   @db.VarChar(100)
  document_url        String    @db.Text
  owner_id_front_url  String    @db.Text
  owner_id_back_url   String?   @db.Text
  status              KycStatus @default(PENDING)
  rejection_reason    String?   @db.Text
  submitted_at        DateTime  @default(now()) @db.Timestamp
  reviewed_at         DateTime? @db.Timestamp
  reviewed_by         String?   @db.Uuid
  created_at          DateTime  @default(now()) @db.Timestamp
  updated_at          DateTime  @updatedAt @db.Timestamp

  // Relations
  salon_profile SalonProfile @relation(fields: [salon_profile_id], references: [id], onDelete: Cascade)
  reviewer      User?        @relation("SalonKycReviewer", fields: [reviewed_by], references: [id], onDelete: SetNull)

  @@map("salon_kyc")
}

model Category {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  parent_id   String?  @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamp
  updated_at  DateTime @updatedAt @db.Timestamp

  // Relations
  parent           Category?         @relation("SubCategories", fields: [parent_id], references: [id], onDelete: SetNull)
  children         Category[]        @relation("SubCategories")
  video_categories VideoCategory[]
  services         ServiceCategory[]

  @@map("categories")
}

model Video {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creator_id     String      @db.Uuid
  title          String      @db.VarChar(255)
  description    String?     @db.Text
  video_url      String      @db.Text
  thumbnail_url  String      @db.Text
  duration       Float       @default(0.0)
  views_count    Int         @default(0)
  likes_count    Int         @default(0)
  comments_count Int         @default(0)
  shares_count   Int         @default(0)
  status         VideoStatus @default(PROCESSING)
  created_at     DateTime    @default(now()) @db.Timestamp
  updated_at     DateTime    @updatedAt @db.Timestamp
  deleted_at     DateTime?   @db.Timestamp

  // Relations
  creator         CreatorProfile  @relation(fields: [creator_id], references: [id], onDelete: Restrict)
  categories      VideoCategory[]
  tags            VideoTag[]
  video_views     VideoView[]
  video_likes     VideoLike[]
  video_comments  VideoComment[]
  video_shares    VideoShare[]
  saved_videos    SavedVideo[]
  watch_histories WatchHistory[]
  reports         Report[]

  @@index([creator_id])
  @@index([status])
  @@index([created_at])
  @@index([deleted_at])
  @@map("videos")
}

model VideoCategory {
  video_id    String   @db.Uuid
  category_id String   @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamp

  // Relations
  video    Video    @relation(fields: [video_id], references: [id], onDelete: Cascade)
  category Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@id([video_id, category_id])
  @@map("video_categories")
}

model Tag {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @unique @db.VarChar(50)
  created_at DateTime @default(now()) @db.Timestamp

  // Relations
  videos VideoTag[]

  @@map("tags")
}

model VideoTag {
  video_id   String   @db.Uuid
  tag_id     String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamp

  // Relations
  video Video @relation(fields: [video_id], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([video_id, tag_id])
  @@map("video_tags")
}

model VideoView {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  video_id      String   @db.Uuid
  user_id       String?  @db.Uuid
  view_duration Float    @default(0.0)
  created_at    DateTime @default(now()) @db.Timestamp

  // Relations
  video Video @relation(fields: [video_id], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([video_id])
  @@index([user_id])
  @@index([created_at])
  @@map("video_views")
}

model VideoLike {
  user_id    String   @db.Uuid
  video_id   String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamp

  // Relations
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video Video @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@id([user_id, video_id])
  @@map("video_likes")
}

model VideoComment {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  video_id    String    @db.Uuid
  user_id     String    @db.Uuid
  parent_id   String?   @db.Uuid
  content     String    @db.Text
  likes_count Int       @default(0)
  created_at  DateTime  @default(now()) @db.Timestamp
  updated_at  DateTime  @updatedAt @db.Timestamp
  deleted_at  DateTime? @db.Timestamp

  // Relations
  video   Video          @relation(fields: [video_id], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  parent  VideoComment?  @relation("CommentReplies", fields: [parent_id], references: [id], onDelete: SetNull)
  replies VideoComment[] @relation("CommentReplies")
  reports Report[]

  @@index([video_id])
  @@index([parent_id])
  @@index([deleted_at])
  @@map("video_comments")
}

model VideoShare {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  video_id   String   @db.Uuid
  user_id    String?  @db.Uuid
  platform   String?  @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamp

  // Relations
  video Video @relation(fields: [video_id], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@map("video_shares")
}

model SavedVideo {
  user_id    String   @db.Uuid
  video_id   String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamp

  // Relations
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video Video @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@id([user_id, video_id])
  @@map("saved_videos")
}

model WatchHistory {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String   @db.Uuid
  video_id      String   @db.Uuid
  last_position Float    @default(0.0)
  completed     Boolean  @default(false)
  watched_at    DateTime @default(now()) @db.Timestamp

  // Relations
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video Video @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@unique([user_id, video_id])
  @@index([watched_at])
  @@map("watch_history")
}

model Follower {
  follower_id  String   @db.Uuid
  following_id String   @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamp

  // Relations
  follower  User @relation("Follower", fields: [follower_id], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [following_id], references: [id], onDelete: Cascade)

  @@id([follower_id, following_id])
  @@map("followers")
}

model Service {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  salon_id    String    @db.Uuid
  name        String    @db.VarChar(255)
  description String?   @db.Text
  price       Decimal   @db.Decimal(10, 2)
  duration    Int // in minutes
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now()) @db.Timestamp
  updated_at  DateTime  @updatedAt @db.Timestamp
  deleted_at  DateTime? @db.Timestamp

  // Relations
  salon            SalonProfile      @relation(fields: [salon_id], references: [id], onDelete: Cascade)
  categories       ServiceCategory[]
  booking_services BookingService[]

  @@index([salon_id])
  @@index([deleted_at])
  @@map("services")
}

model ServiceCategory {
  service_id  String   @db.Uuid
  category_id String   @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamp

  // Relations
  service  Service  @relation(fields: [service_id], references: [id], onDelete: Cascade)
  category Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@id([service_id, category_id])
  @@map("service_categories")
}

model Booking {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id    String        @db.Uuid
  salon_id       String        @db.Uuid
  staff_id       String?       @db.Uuid
  booking_date   DateTime      @db.Date
  start_time     DateTime      @db.Timestamp
  end_time       DateTime      @db.Timestamp
  total_price    Decimal       @db.Decimal(10, 2)
  status         BookingStatus @default(PENDING)
  payment_status PaymentStatus @default(PENDING)
  notes          String?       @db.Text
  created_at     DateTime      @default(now()) @db.Timestamp
  updated_at     DateTime      @updatedAt @db.Timestamp

  // Relations
  customer User             @relation("CustomerBookings", fields: [customer_id], references: [id], onDelete: Restrict)
  salon    SalonProfile     @relation(fields: [salon_id], references: [id], onDelete: Restrict)
  staff    Staff?           @relation(fields: [staff_id], references: [id], onDelete: SetNull)
  services BookingService[]
  reviews  Review[]

  @@index([customer_id])
  @@index([salon_id])
  @@index([staff_id])
  @@index([booking_date])
  @@index([status])
  @@map("bookings")
}

model BookingService {
  booking_id       String   @db.Uuid
  service_id       String   @db.Uuid
  price_at_booking Decimal  @db.Decimal(10, 2)
  created_at       DateTime @default(now()) @db.Timestamp

  // Relations
  booking Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  service Service @relation(fields: [service_id], references: [id], onDelete: Restrict)

  @@id([booking_id, service_id])
  @@map("booking_services")
}

model Staff {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  salon_id   String    @db.Uuid
  user_id    String?   @unique @db.Uuid
  name       String    @db.VarChar(100)
  avatar_url String?   @db.Text
  email      String?   @db.VarChar(255)
  phone      String?   @db.VarChar(50)
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now()) @db.Timestamp
  updated_at DateTime  @updatedAt @db.Timestamp
  deleted_at DateTime? @db.Timestamp

  // Relations
  salon    SalonProfile @relation(fields: [salon_id], references: [id], onDelete: Cascade)
  user     User?        @relation(fields: [user_id], references: [id], onDelete: SetNull)
  bookings Booking[]

  @@index([deleted_at])
  @@map("staff")
}

model Gallery {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  salon_id    String   @db.Uuid
  image_url   String   @db.Text
  caption     String?  @db.VarChar(255)
  is_featured Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamp
  updated_at  DateTime @updatedAt @db.Timestamp

  // Relations
  salon SalonProfile @relation(fields: [salon_id], references: [id], onDelete: Cascade)

  @@map("galleries")
}

model Offer {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  salon_id          String       @db.Uuid
  title             String       @db.VarChar(255)
  description       String?      @db.Text
  promo_code        String?      @unique @db.VarChar(50)
  discount_type     DiscountType
  discount_value    Decimal      @db.Decimal(10, 2)
  min_booking_value Decimal?     @db.Decimal(10, 2)
  start_date        DateTime     @db.Timestamp
  end_date          DateTime     @db.Timestamp
  usage_limit       Int?
  usage_count       Int          @default(0)
  is_active         Boolean      @default(true)
  created_at        DateTime     @default(now()) @db.Timestamp
  updated_at        DateTime     @updatedAt @db.Timestamp

  // Relations
  salon SalonProfile @relation(fields: [salon_id], references: [id], onDelete: Cascade)

  @@index([salon_id])
  @@index([promo_code])
  @@index([start_date, end_date])
  @@map("offers")
}

model Review {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  booking_id String?   @unique @db.Uuid
  salon_id   String?   @db.Uuid
  creator_id String?   @db.Uuid
  rating     Int
  comment    String?   @db.Text
  created_at DateTime  @default(now()) @db.Timestamp
  updated_at DateTime  @updatedAt @db.Timestamp
  deleted_at DateTime? @db.Timestamp

  // Relations
  user    User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  booking Booking?        @relation(fields: [booking_id], references: [id], onDelete: SetNull)
  salon   SalonProfile?   @relation(fields: [salon_id], references: [id], onDelete: Cascade)
  creator CreatorProfile? @relation(fields: [creator_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([salon_id])
  @@index([creator_id])
  @@index([deleted_at])
  @@map("reviews")
}

model Wallet {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @unique @db.Uuid
  balance    Decimal  @default(0.00) @db.Decimal(12, 2)
  currency   String   @default("USD") @db.VarChar(10)
  created_at DateTime @default(now()) @db.Timestamp
  updated_at DateTime @updatedAt @db.Timestamp

  // Relations
  user         User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wallet_id    String            @db.Uuid
  amount       Decimal           @db.Decimal(12, 2)
  type         TransactionType
  status       TransactionStatus @default(PENDING)
  reference_id String?           @db.VarChar(255)
  description  String?           @db.Text
  created_at   DateTime          @default(now()) @db.Timestamp

  // Relations
  wallet Wallet @relation(fields: [wallet_id], references: [id], onDelete: Restrict)

  @@index([wallet_id])
  @@index([type])
  @@index([status])
  @@index([created_at])
  @@map("wallet_transactions")
}

model WithdrawRequest {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String         @db.Uuid
  amount           Decimal        @db.Decimal(12, 2)
  status           WithdrawStatus @default(PENDING)
  rejection_reason String?        @db.Text
  payout_method    String         @db.VarChar(100)
  payout_details   Json           @default("{}")
  created_at       DateTime       @default(now()) @db.Timestamp
  updated_at       DateTime       @updatedAt @db.Timestamp

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Restrict)

  @@index([user_id])
  @@index([status])
  @@map("withdraw_requests")
}

model Course {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creator_id      String    @db.Uuid
  title           String    @db.VarChar(255)
  description     String?   @db.Text
  cover_image_url String    @db.Text
  price           Decimal   @default(0.00) @db.Decimal(10, 2)
  is_published    Boolean   @default(false)
  created_at      DateTime  @default(now()) @db.Timestamp
  updated_at      DateTime  @updatedAt @db.Timestamp
  deleted_at      DateTime? @db.Timestamp

  // Relations
  creator     CreatorProfile     @relation(fields: [creator_id], references: [id], onDelete: Restrict)
  lessons     CourseLesson[]
  enrollments CourseEnrollment[]

  @@index([creator_id])
  @@index([deleted_at])
  @@map("courses")
}

model CourseLesson {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  course_id   String    @db.Uuid
  title       String    @db.VarChar(255)
  description String?   @db.Text
  video_url   String    @db.Text
  duration    Float     @default(0.0)
  sort_order  Int       @default(0)
  created_at  DateTime  @default(now()) @db.Timestamp
  updated_at  DateTime  @updatedAt @db.Timestamp
  deleted_at  DateTime? @db.Timestamp

  // Relations
  course Course @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@index([course_id])
  @@index([sort_order])
  @@index([deleted_at])
  @@map("course_lessons")
}

model CourseEnrollment {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String    @db.Uuid
  course_id        String    @db.Uuid
  progress_percent Float     @default(0.0)
  completed_at     DateTime? @db.Timestamp
  certificate_url  String?   @db.Text
  created_at       DateTime  @default(now()) @db.Timestamp
  updated_at       DateTime  @updatedAt @db.Timestamp

  // Relations
  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  course Course @relation(fields: [course_id], references: [id], onDelete: Restrict)

  @@unique([user_id, course_id])
  @@map("course_enrollments")
}

model Earning {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String        @db.Uuid
